{
  "name": "@vaultmcp/mcp-proxy",
  "version": "0.0.1",
  "description": "MCP prompt-injection scanning proxy",
  "type": "module",
  "bin": {
    "mcp-proxy": "./dist/index.js",
    "vault-audit": "./dist/audit-view.js",
    "vault-check": "./dist/check.js",
    "vault-init": "./dist/init.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "view-audit": "tsx src/cli/audit-view.ts",
    "check": "tsx src/cli/check.ts",
    "init": "tsx src/cli/init.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "bench:l3": "tsx bench/layer3-floor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@vaultmcp/corpus": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
